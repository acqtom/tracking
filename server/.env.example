# Used only to HMAC-sign the short-lived OAuth "state" param (CSRF protection
# during the redirect round trip). Not a login/session system - the dashboard's
# own password gate already handles that layer. Set this to any long random string.
SESSION_SECRET=change-me-to-a-long-random-string
